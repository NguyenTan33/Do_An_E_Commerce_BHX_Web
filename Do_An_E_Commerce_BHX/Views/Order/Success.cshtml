    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container text-center my-5 py-5">
    <div class="card shadow-sm p-4 mx-auto" style="max-width: 500px;">
        <div class="text-success mb-3">
            <i class="fas fa-check-circle display-1"></i>
        </div>
        <h2 class="font-weight-bold text-success">Đặt Hàng Thành Công!</h2>
        <p class="text-muted mt-2">Cảm ơn bạn đã mua sắm. Đơn hàng của bạn đang được hệ thống tiếp nhận và xử lý.</p>
        <div class="mt-4">
            <a href="/" class="btn btn-primary px-4">Tiếp tục mua hàng</a>
        </div>
    </div>
</div>