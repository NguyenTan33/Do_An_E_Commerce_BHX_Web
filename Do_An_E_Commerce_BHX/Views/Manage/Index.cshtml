@model Do_An_E_Commerce_BHX.Models.IndexViewModel
@{
    Layout = null;
    ViewBag.Title = "Quản lý tài khoản";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --leaf: #20b04c;
            --forest: #0e8133;
            --bg: #f4f7f6;
            --ink: #1f2937;
            --muted: #6b7280;
            --card: #ffffff;
            --line: #e5e7eb;
            --amber: #f59e0b;
        }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--bg);
            color: var(--ink);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .header-bar {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            padding: 20px 30px;
            box-sizing: border-box;
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--forest);
            text-decoration: none;
            font-weight: 600;
            font-size: 15px;
            padding: 8px 16px;
            background: rgba(32, 176, 76, 0.1);
            border-radius: 8px;
            transition: all 0.2s ease;
        }

            .btn-back:hover {
                background: var(--leaf);
                color: #fff;
            }

        .account-card {
            background: var(--card);
            width: 100%;
            max-width: 540px;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            overflow: hidden;
            margin: 80px 20px 40px;
        }

        .card-header {
            background: linear-gradient(135deg, var(--leaf), var(--forest));
            padding: 30px 20px;
            text-align: center;
            color: #fff;
        }

        .avatar-circle {
            width: 80px;
            height: 80px;
            background: #fff;
            color: var(--forest);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            margin: 0 auto 15px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .user-name {
            margin: 0;
            font-size: 22px;
            font-weight: 700;
        }

        .loyalty-points {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: rgba(255, 255, 255, 0.2);
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 600;
            margin-top: 12px;
        }

            .loyalty-points i {
                color: #ffda44;
            }

        .card-body {
            padding: 0 24px 24px;
        }

        .status-msg {
            color: var(--leaf);
            font-weight: 600;
            text-align: center;
            margin: 20px 0 0;
            font-size: 14px;
        }

        .setting-group {
            margin-top: 24px;
        }

        .setting-title {
            font-size: 13px;
            text-transform: uppercase;
            color: var(--muted);
            letter-spacing: 0.05em;
            font-weight: 700;
            margin-bottom: 12px;
            padding-bottom: 8px;
            border-bottom: 1px solid var(--line);
        }

        .setting-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 0;
            border-bottom: 1px dashed var(--line);
        }

            .setting-item:last-child {
                border-bottom: none;
            }

        .setting-info h4 {
            margin: 0 0 4px;
            font-size: 15px;
            color: var(--ink);
        }

        .setting-info p {
            margin: 0;
            font-size: 13px;
            color: var(--muted);
            line-height: 1.4;
        }

        .btn-action {
            text-decoration: none;
            color: var(--leaf);
            font-weight: 600;
            font-size: 14px;
            background: rgba(32, 176, 76, 0.1);
            padding: 8px 16px;
            border-radius: 6px;
            transition: background 0.2s;
            cursor: pointer;
            border: none;
            white-space: nowrap;
        }

            .btn-action:hover {
                background: rgba(32, 176, 76, 0.2);
            }

        .inline-edit-box {
            display: none;
            background: #fafafa;
            border-radius: 8px;
            padding: 15px;
            width: 100%;
            box-sizing: border-box;
            border: 1px solid var(--line);
            margin-top: 8px;
        }
    </style>
</head>
<body>

    <div class="header-bar">
        <a href="@Url.Action("Index", "Home", new { area = "" })" class="btn-back">
            <i class="fa-solid fa-arrow-left"></i> Quay lại trang chủ
        </a>
    </div>

    <div class="account-card">
        <div class="card-header">
            <div class="avatar-circle">
                <i class="fa-regular fa-user"></i>
            </div>
            <h2 class="user-name">@Model.FullName</h2>
            <div class="loyalty-points">
                <i class="fa-solid fa-star"></i> @Model.LoyaltyPoints điểm tích lũy
            </div>
        </div>

        <div class="card-body">
            @if (!string.IsNullOrEmpty(ViewBag.StatusMessage))
            {
                <p class="status-msg"><i class="fa-solid fa-circle-check"></i> @ViewBag.StatusMessage</p>
            }

            <div class="setting-group">
                <div class="setting-title">Thông tin cá nhân</div>

                <!-- 1. HỌ VÀ TÊN (SỬA TẠI CHỖ) -->
                <div class="setting-item" id="name-display-block">
                    <div class="setting-info">
                        <h4>Họ và Tên</h4>
                        <p>@Model.FullName</p>
                    </div>
                    <button type="button" class="btn-action" onclick="toggleEditName()">Cập nhật</button>
                </div>

                <div class="inline-edit-box" id="name-edit-block">
                    @using (Html.BeginForm("UpdateName", "Manage", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <div style="display: flex; flex-direction: column; gap: 10px;">
                            <label style="font-size: 13px; color: var(--ink); font-weight: 600;">Nhập họ tên mới</label>
                            <input type="text" name="FullName" value="@Model.FullName" required
                                   style="padding: 10px 12px; border: 1px solid var(--line); border-radius: 6px; outline: none; font-family: 'Inter', sans-serif;" />

                            <div style="display: flex; justify-content: flex-end; gap: 8px; margin-top: 5px;">
                                <button type="button" class="btn-action" style="background: transparent; color: var(--muted); border: 1px solid var(--line);" onclick="toggleEditName()">Hủy</button>
                                <button type="submit" class="btn-action" style="background: var(--leaf); color: #fff;">Lưu thay đổi</button>
                            </div>
                        </div>
                    }
                </div>

                <!-- 2. SỐ ĐIỆN THOẠI (SỬA/THÊM TẠI CHỖ) -->
                <div class="setting-item" id="phone-display-block">
                    <div class="setting-info">
                        <h4>Số điện thoại</h4>
                        <p>@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Chưa cập nhật" : Model.PhoneNumber)</p>
                    </div>
                    <button type="button" class="btn-action" onclick="toggleEditPhone()">
                        @(string.IsNullOrEmpty(Model.PhoneNumber) ? "Thêm SĐT" : "Cập nhật")
                    </button>
                </div>

                <div class="inline-edit-box" id="phone-edit-block">
                    @using (Html.BeginForm("UpdatePhone", "Manage", new { area = "Admin" }, FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <div style="display: flex; flex-direction: column; gap: 10px;">
                            <label style="font-size: 13px; color: var(--ink); font-weight: 600;">Nhập số điện thoại liên hệ</label>
                            <input type="text" name="PhoneNumber" value="@Model.PhoneNumber" placeholder="VD: 0901234567" required
                                   style="padding: 10px 12px; border: 1px solid var(--line); border-radius: 6px; outline: none; font-family: 'Inter', sans-serif;" />

                            <div style="display: flex; justify-content: flex-end; gap: 8px; margin-top: 5px;">
                                <button type="button" class="btn-action" style="background: transparent; color: var(--muted); border: 1px solid var(--line);" onclick="toggleEditPhone()">Hủy</button>
                                <button type="submit" class="btn-action" style="background: var(--leaf); color: #fff;">Lưu SĐT</button>
                            </div>
                        </div>
                    }
                </div>

                <!-- 3. ĐỊA CHỈ NHẬN HÀNG -->
                <div class="setting-item">
                    <div class="setting-info">
                        <h4>Địa chỉ nhận hàng</h4>
                        <p>Quản lý và thiết lập địa chỉ giao hàng mặc định</p>
                    </div>
                    <a href="@Url.Action("Index", "UserAddress", new { area = "" })" class="btn-action">
                        Sổ địa chỉ
                    </a>
                </div>
            </div>

            <div class="setting-group">
                <div class="setting-title">Bảo mật & Đăng nhập</div>

                <div class="setting-item">
                    <div class="setting-info">
                        <h4>Mật khẩu</h4>
                        <p>Bảo vệ tài khoản của bạn</p>
                    </div>
                    @if (Model.HasPassword)
                    {
                        <a href="@Url.Action("ChangePassword", "Manage")" class="btn-action">Đổi mật khẩu</a>
                    }
                    else
                    {
                        <a href="@Url.Action("SetPassword", "Manage")" class="btn-action">Tạo mật khẩu</a>
                    }
                </div>

                <div class="setting-item">
                    <div class="setting-info">
                        <h4>Tài khoản liên kết</h4>
                        <p>Đang có @(Model.Logins?.Count ?? 0) liên kết ngoài</p>
                    </div>
                    <a href="@Url.Action("ManageLogins", "Manage")" class="btn-action">Quản lý</a>
                </div>
            </div>
        </div>
    </div>

    <script>
        function toggleEditName() {
            var displayBlock = document.getElementById("name-display-block");
            var editBlock = document.getElementById("name-edit-block");

            if (editBlock.style.display === "block") {
                displayBlock.style.display = "flex";
                editBlock.style.display = "none";
            } else {
                displayBlock.style.display = "none";
                editBlock.style.display = "block";
            }
        }

        function toggleEditPhone() {
            var displayBlock = document.getElementById("phone-display-block");
            var editBlock = document.getElementById("phone-edit-block");

            if (editBlock.style.display === "block") {
                displayBlock.style.display = "flex";
                editBlock.style.display = "none";
            } else {
                displayBlock.style.display = "none";
                editBlock.style.display = "block";
            }
        }
    </script>
</body>
</html>