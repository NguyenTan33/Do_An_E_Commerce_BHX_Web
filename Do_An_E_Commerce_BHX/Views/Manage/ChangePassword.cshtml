@model Do_An_E_Commerce_BHX.Models.ChangePasswordViewModel
@{
    Layout = null;
    ViewBag.Title = "Đổi mật khẩu";
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --leaf: #20b04c;
            --forest: #0e8133;
            --bg: #f4f7f6;
            --ink: #1f2937;
            --muted: #6b7280;
            --card: #ffffff;
            --line: #e5e7eb;
            --danger: #ef4444;
        }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--bg);
            color: var(--ink);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .header-bar {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            padding: 20px 30px;
            box-sizing: border-box;
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--forest);
            text-decoration: none;
            font-weight: 600;
            font-size: 15px;
            padding: 8px 16px;
            background: rgba(32, 176, 76, 0.1);
            border-radius: 8px;
            transition: all 0.2s ease;
        }

            .btn-back:hover {
                background: var(--leaf);
                color: #fff;
            }

        .card-container {
            background: var(--card);
            width: 100%;
            max-width: 480px;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            overflow: hidden;
            margin: 80px 20px 40px;
        }

        .card-header {
            background: linear-gradient(135deg, var(--leaf), var(--forest));
            padding: 30px 20px;
            text-align: center;
            color: #fff;
        }

        .header-icon {
            width: 60px;
            height: 60px;
            background: #fff;
            color: var(--forest);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            margin: 0 auto 12px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .card-header h2 {
            margin: 0;
            font-size: 20px;
            font-weight: 700;
        }

        .card-body {
            padding: 28px 24px;
        }

        .form-group {
            margin-bottom: 18px;
        }

            .form-group label {
                display: block;
                font-size: 13px;
                font-weight: 600;
                color: var(--ink);
                margin-bottom: 6px;
            }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .form-control {
            width: 100%;
            padding: 11px 40px 11px 14px;
            border: 1px solid var(--line);
            border-radius: 8px;
            font-family: 'Inter', sans-serif;
            font-size: 14px;
            outline: none;
            box-sizing: border-box;
            transition: border-color 0.2s;
        }

            .form-control:focus {
                border-color: var(--leaf);
            }

        .toggle-password {
            position: absolute;
            right: 12px;
            color: var(--muted);
            cursor: pointer;
            font-size: 14px;
        }

        .validation-summary {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: var(--danger);
            padding: 12px;
            border-radius: 8px;
            font-size: 13px;
            margin-bottom: 18px;
        }

            .validation-summary ul {
                margin: 0;
                padding-left: 18px;
            }

        .btn-submit {
            width: 100%;
            background: var(--leaf);
            color: #fff;
            border: none;
            padding: 12px;
            border-radius: 8px;
            font-family: 'Inter', sans-serif;
            font-weight: 600;
            font-size: 15px;
            cursor: pointer;
            transition: background 0.2s;
            margin-top: 10px;
        }

            .btn-submit:hover {
                background: var(--forest);
            }
    </style>
</head>
<body>

    <div class="header-bar">
        <a href="@Url.Action("Index", "Manage")" class="btn-back">
            <i class="fa-solid fa-arrow-left"></i> Quay lại tài khoản
        </a>
    </div>

    <div class="card-container">
        <div class="card-header">
            <div class="header-icon">
                <i class="fa-solid fa-key"></i>
            </div>
            <h2>Đổi mật khẩu</h2>
        </div>

        <div class="card-body">
            @using (Html.BeginForm("ChangePassword", "Manage", FormMethod.Post, new { role = "form" }))
            {
                @Html.AntiForgeryToken()

                if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(""))
                {
                    <div class="validation-summary">
                        @Html.ValidationSummary(true, "")
                    </div>
                }

                <div class="form-group">
                    <label for="OldPassword">Mật khẩu hiện tại</label>
                    <div class="input-wrapper">
                        @Html.PasswordFor(m => m.OldPassword, new { @class = "form-control", placeholder = "Nhập mật khẩu cũ", id = "OldPassword" })
                        <i class="fa-regular fa-eye toggle-password" onclick="togglePasswordVisibility('OldPassword', this)"></i>
                    </div>
                    @Html.ValidationMessageFor(m => m.OldPassword, "", new { @style = "color: var(--danger); font-size: 12px; margin-top: 4px; display: block;" })
                </div>

                <div class="form-group">
                    <label for="NewPassword">Mật khẩu mới</label>
                    <div class="input-wrapper">
                        @Html.PasswordFor(m => m.NewPassword, new { @class = "form-control", placeholder = "Tối thiểu 6 ký tự", id = "NewPassword" })
                        <i class="fa-regular fa-eye toggle-password" onclick="togglePasswordVisibility('NewPassword', this)"></i>
                    </div>
                    @Html.ValidationMessageFor(m => m.NewPassword, "", new { @style = "color: var(--danger); font-size: 12px; margin-top: 4px; display: block;" })
                </div>

                <div class="form-group">
                    <label for="ConfirmPassword">Xác nhận mật khẩu mới</label>
                    <div class="input-wrapper">
                        @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", placeholder = "Nhập lại mật khẩu mới", id = "ConfirmPassword" })
                        <i class="fa-regular fa-eye toggle-password" onclick="togglePasswordVisibility('ConfirmPassword', this)"></i>
                    </div>
                    @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @style = "color: var(--danger); font-size: 12px; margin-top: 4px; display: block;" })
                </div>

                <button type="submit" class="btn-submit">Cập nhật mật khẩu</button>
            }
        </div>
    </div>

    <script>function togglePasswordVisibility(inputId, icon) {
            var input = document.getElementById(inputId);
            if (input.type === "password") {
                input.type = "text";
                icon.classList.remove("fa-eye");
                icon.classList.add("fa-eye-slash");
            } else {
                input.type = "password";
                icon.classList.remove("fa-eye-slash");
                icon.classList.add("fa-eye");
            }
        }</script>
</body>
</html>