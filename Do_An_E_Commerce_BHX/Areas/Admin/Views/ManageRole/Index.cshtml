@model IEnumerable<Microsoft.AspNet.Identity.EntityFramework.IdentityRole>

@{
    ViewData["Title"] = "Quản lý Phân quyền";
    ViewData["Subtitle"] = "Danh sách các nhóm quyền trong hệ thống";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

@section Styles {
    <style>
        :root {
            --navy: #16233F;
            --navy-deep: #0F1A30;
            --paper: #FAF8F4;
            --ink: #22262E;
            --muted: #6B7280;
            --line: #E5E1D8;
            --amber: #E2792B;
            --red: #C4453A;
        }

        .header, .filter-container, .table-wrap {
            width: 100%;
            max-width: 100%;
        }

        .header {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 24px;
            border-bottom: 3px solid var(--navy);
            padding-bottom: 16px;
        }

        .eyebrow {
            font-family: 'JetBrains Mono', monospace;
            font-size: 12px;
            letter-spacing: 0.18em;
            color: var(--muted);
            text-transform: uppercase;
            margin: 0 0 6px;
        }

        h2 {
            font-family: 'Oswald', sans-serif;
            font-weight: 700;
            font-size: 30px;
            letter-spacing: 0.01em;
            color: var(--navy-deep);
            margin: 0;
            text-transform: uppercase;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .count-badge {
            font-family: 'JetBrains Mono', monospace;
            font-size: 13px;
            background: var(--navy);
            color: #fff;
            padding: 6px 14px;
            border-radius: 3px;
        }

        .btn-add {
            font-family: 'Oswald', sans-serif;
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            background: var(--amber);
            color: #fff;
            padding: 9px 16px;
            border-radius: 4px;
            text-decoration: none;
            transition: opacity 0.15s ease;
        }

            .btn-add:hover {
                opacity: 0.9;
            }

        .filter-panel {
            background: #fff;
            border-radius: 8px;
            padding: 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,.08);
            border: 1px solid var(--line);
            margin-bottom: 20px;
            display: flex;
            gap: 18px;
            align-items: flex-end;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
            min-width: 260px;
            flex: 1;
        }

            .filter-group label {
                font-weight: 600;
                font-size: 13px;
                margin-bottom: 6px;
                color: var(--navy-deep);
            }

            .filter-group input {
                height: 40px;
                border: 1px solid var(--line);
                border-radius: 6px;
                padding: 0 12px;
                outline: none;
            }

                .filter-group input:focus {
                    border-color: var(--navy);
                }

        .btn-search {
            height: 40px;
            padding: 0 22px;
            border: none;
            border-radius: 6px;
            background: var(--navy);
            color: #fff;
            font-family: 'Oswald', sans-serif;
            font-size: 13px;
            text-transform: uppercase;
            cursor: pointer;
        }

        .btn-reset {
            height: 40px;
            padding: 0 22px;
            border-radius: 6px;
            text-decoration: none;
            background: #E5E1D8;
            color: var(--ink);
            font-family: 'Oswald', sans-serif;
            font-size: 13px;
            text-transform: uppercase;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-left: 10px;
        }

        table {
            border-collapse: collapse;
            width: 100%;
        }

        .table-wrap {
            background: #fff;
            border-radius: 6px;
            box-shadow: 0 1px 3px rgba(15,26,48,0.08);
            border: 1px solid var(--line);
            overflow: hidden;
        }

        thead th {
            background: var(--navy);
            color: #fff;
            font-family: 'Oswald', sans-serif;
            font-size: 13px;
            text-transform: uppercase;
            text-align: left;
            padding: 14px 16px;
        }

        tbody td {
            padding: 13px 16px;
            border-bottom: 1px solid var(--line);
            font-size: 14px;
            vertical-align: middle;
        }

        tbody tr:hover {
            background: #F3F0E9;
        }

        .role-name {
            font-weight: 600;
            color: var(--navy-deep);
            font-size: 15px;
        }

        .role-id {
            font-family: 'JetBrains Mono', monospace;
            color: var(--muted);
            font-size: 13px;
        }

        .action-cell {
            white-space: nowrap;
            text-align: right;
        }

            .action-cell form {
                display: inline-block;
                margin: 0;
            }

        .icon-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 30px;
            height: 30px;
            border-radius: 4px;
            border: 1.5px solid var(--line);
            background: #fff;
            cursor: pointer;
            margin-left: 6px;
        }

            .icon-btn svg {
                width: 15px;
                height: 15px;
            }

            .icon-btn.edit {
                color: var(--navy);
            }

                .icon-btn.edit:hover {
                    background: #EEF1F6;
                }

            .icon-btn.delete {
                color: var(--red);
            }

                .icon-btn.delete:hover {
                    background: #FBEAE8;
                }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--muted);
        }

        /* Modal */
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(15,26,48,0.55);
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

            .modal-overlay.active {
                display: flex;
            }

        .modal-box {
            background: #fff;
            border-radius: 6px;
            padding: 28px;
            max-width: 400px;
            width: 90%;
        }

        .modal-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            margin-top: 20px;
        }

            .modal-actions button {
                padding: 10px 18px;
                border-radius: 4px;
                border: none;
                font-weight: 600;
                cursor: pointer;
                text-transform: uppercase;
                font-family: 'Oswald', sans-serif;
            }

        .modal-cancel {
            border: 1.5px solid var(--line);
            background: transparent;
        }

        .modal-delete {
            background: var(--red);
            color: #fff;
        }
    </style>
}

<div class="header">
    <div>
        <p class="eyebrow">Hệ thống &middot; Phân quyền</p>
        <h2>Danh sách nhóm quyền</h2>
    </div>
    <div class="header-right">
        <span class="count-badge">@(Model?.Count() ?? 0) Quyền</span>
        <a href="@Url.Action("ThemRole", "ManageRole")" class="btn-add">+ Thêm nhóm quyền</a>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div style="background: #FDE8E8; color: var(--red); padding: 12px 16px; border-radius: 6px; margin-bottom: 20px; font-weight: 500;">
        ⚠️ @TempData["Error"]
    </div>
}

<div class="filter-panel">
    @using (Html.BeginForm("Index", "ManageRole", FormMethod.Get, new { style = "display:flex; width: 100%; gap: 18px; align-items: flex-end;" }))
    {
        <div class="filter-group">
            <label>Tìm tên quyền</label>
            <input type="text" name="tuKhoa" value="@Request["tuKhoa"]" placeholder="Nhập tên quyền..." />
        </div>
        <div>
            <button type="submit" class="btn-search">🔍 Tìm kiếm</button>
            <a href="@Url.Action("Index")" class="btn-reset">Đặt lại</a>
        </div>
    }
</div>

<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th style="width: 250px;">Tên quyền (Role Name)</th>
                <th>Mã định danh (ID)</th>
                <th style="text-align:right;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var role in Model)
                {
                    <tr>
                        <td class="role-name">
                            <span style="display: inline-block; padding: 4px 10px; background: #EEF1F6; border-radius: 4px; border: 1px solid #D0D7E7;">
                                @role.Name
                            </span>
                        </td>
                        <td class="role-id">@role.Id</td>
                        <td class="action-cell">
                            <a href="@Url.Action("SuaRole", "ManageRole", new { id = role.Id })" class="icon-btn edit" title="Sửa quyền">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                </svg>
                            </a>

                            @using (Html.BeginForm("XoaRole", "ManageRole", FormMethod.Post, new { id = "formDelete_" + role.Id }))
                            {
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@role.Id" />
                                <button type="button" class="icon-btn delete" title="Xóa quyền"
                                        onclick="openDeleteModal('@role.Id', '@role.Name')">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="3 6 5 6 21 6"></polyline>
                                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                                        <path d="M10 11v6"></path>
                                        <path d="M14 11v6"></path>
                                        <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"></path>
                                    </svg>
                                </button>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="3" class="empty-state">Chưa có quyền nào trong hệ thống.</td></tr>
            }
        </tbody>
    </table>
</div>

<div class="modal-overlay" id="deleteModal">
    <div class="modal-box">
        <h3 style="color: var(--red);">Xác nhận xóa quyền</h3>
        <p style="font-size:14px; color:var(--muted); margin-bottom:20px;">
            Bạn có chắc chắn muốn xóa nhóm quyền <strong id="deleteRoleName" style="color:var(--ink);"></strong>? Các tài khoản đang dùng quyền này có thể bị mất truy cập.
        </p>
        <div class="modal-actions">
            <button type="button" class="modal-cancel" onclick="closeDeleteModal()">Hủy</button>
            <button type="button" class="modal-delete" onclick="confirmDelete()">Xóa quyền</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>let roleIdToDelete = null;

        function openDeleteModal(id, name) {
            roleIdToDelete = id;
            document.getElementById('deleteRoleName').textContent = name;
            document.getElementById('deleteModal').classList.add('active');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.remove('active');
        }

        function confirmDelete() {
            if (roleIdToDelete) {
                document.getElementById('formDelete_' + roleIdToDelete).submit();
            }
        }

        document.getElementById('deleteModal').addEventListener('click', function (e) {
            if (e.target === this) closeDeleteModal();
        });</script>
}