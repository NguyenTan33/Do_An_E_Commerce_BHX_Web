@model Do_An_E_Commerce_BHX.Areas.Admin.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Bảng điều khiển";
    ViewData["Subtitle"] = "Thống kê tổng quan hoạt động kinh doanh";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

@section Styles {
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css" />
    <style>
        :root {
            --forest: #163B2E;
            --forest-deep: #0E2A20;
            --leaf: #3F8F5C;
            --leaf-dark: #1F6B3F;
            --paper: #F7F4E9;
            --card: #FFFFFF;
            --ink: #1E2A22;
            --muted: #737B6C;
            --line: #DBD5C2;
            --amber: #E2A33B;
            --amber-dark: #A9711A;
            --tomato: #C1432E;
            --tomato-dark: #A6382A;
            --sky: #2F6FA6;
        }

        body {
            background: var(--paper);
        }

        h1, h2, h3, h4, h5, .display-face {
            font-family: 'Anton', 'Inter', sans-serif;
            letter-spacing: 0.03em;
        }

        /* ===== Header band (market awning) ===== */
        .header-band {
            position: relative;
            background: var(--forest);
            background-image: repeating-linear-gradient(115deg, rgba(255,255,255,0.035) 0 26px, transparent 26px 52px);
            margin: -24px -24px 46px;
            padding: 30px 32px 40px;
            color: #fff;
        }

        .header-inner {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 12px;
        }

        .eyebrow {
            font-family: 'JetBrains Mono', monospace;
            font-size: 12px;
            letter-spacing: 0.22em;
            color: rgba(255,255,255,0.65);
            text-transform: uppercase;
            margin: 0 0 8px;
        }

            .eyebrow::before {
                content: "◆ ";
                color: var(--amber);
            }

        h2.page-title {
            font-family: 'Anton', sans-serif;
            font-weight: 400;
            font-size: 34px;
            letter-spacing: 0.04em;
            color: #fff;
            margin: 0;
            text-transform: uppercase;
        }

        .header-tag {
            font-family: 'JetBrains Mono', monospace;
            font-size: 12px;
            color: rgba(255,255,255,0.8);
            border: 1px dashed rgba(255,255,255,0.35);
            border-radius: 20px;
            padding: 6px 14px;
        }

        .awning-scallop {
            position: absolute;
            left: 0;
            bottom: -1px;
            width: 100%;
            height: 18px;
            display: block;
        }

        /* ===== Filter panel (order slip) ===== */
        .filter-container {
            margin: -66px 0 28px;
            position: relative;
            z-index: 2;
        }

        .filter-panel {
            background: var(--card);
            border-radius: 10px;
            padding: 20px 22px;
            box-shadow: 0 10px 30px rgba(14,42,32,0.14);
            border: 1px solid var(--line);
            border-top: 3px solid var(--leaf);
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
            align-items: flex-end;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
            flex: 1;
            min-width: 180px;
        }

            .filter-group label {
                font-weight: 700;
                font-size: 11px;
                text-transform: uppercase;
                letter-spacing: 0.06em;
                margin-bottom: 7px;
                color: var(--muted);
            }

            .filter-group input,
            .filter-group select {
                height: 42px;
                border: 1px solid var(--line);
                border-radius: 6px;
                padding: 0 12px;
                font-family: 'Inter', sans-serif;
                font-size: 14px;
                color: var(--ink);
                background: #fff;
                outline: none;
                transition: border-color 0.15s ease, box-shadow 0.15s ease;
            }

                .filter-group input:focus,
                .filter-group select:focus,
                .btn-search:focus-visible {
                    border-color: var(--leaf);
                    box-shadow: 0 0 0 3px rgba(63,143,92,0.18);
                }

        .btn-search {
            height: 42px;
            padding: 0 24px;
            border: none;
            border-radius: 6px;
            background: var(--forest);
            color: #fff;
            font-family: 'Inter', sans-serif;
            font-weight: 700;
            font-size: 13px;
            letter-spacing: 0.03em;
            text-transform: uppercase;
            cursor: pointer;
            transition: background 0.15s ease, transform 0.15s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .btn-search:hover {
                background: var(--leaf-dark);
                transform: translateY(-1px);
            }

        /* ===== Stat cards — hang-tag ticket style ===== */
        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
            gap: 22px;
            margin-bottom: 28px;
        }

        .stat-card {
            position: relative;
            background: var(--card);
            padding: 22px 22px 22px 30px;
            border: 1px solid var(--line);
            box-shadow: 0 1px 3px rgba(15,26,48,0.05);
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: 10px;
            clip-path: polygon(0 0, calc(100% - 18px) 0, 100% 18px, 100% 100%, 0 100%);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            animation: riseIn 0.5s ease both;
        }

            .stat-card:nth-child(2) {
                animation-delay: 0.05s;
            }

            .stat-card:nth-child(3) {
                animation-delay: 0.1s;
            }

            .stat-card:nth-child(4) {
                animation-delay: 0.15s;
            }

            .stat-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 24px rgba(15,26,48,0.1);
            }

            .stat-card::before {
                content: "";
                position: absolute;
                top: 18px;
                left: 10px;
                width: 10px;
                height: 10px;
                border-radius: 50%;
                background: var(--paper);
                border: 1px solid var(--line);
            }

            .stat-card::after {
                content: "";
                position: absolute;
                top: 12px;
                bottom: 12px;
                left: 20px;
                border-left: 1px dashed var(--line);
            }

        .stat-info h5 {
            margin: 0 0 8px 0;
            font-family: 'Inter', sans-serif;
            font-size: 12px;
            color: var(--muted);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .stat-info h3 {
            margin: 0;
            font-size: 23px;
            font-weight: 700;
            color: var(--forest-deep);
            font-family: 'JetBrains Mono', monospace;
        }

        .stat-icon {
            width: 46px;
            height: 46px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 19px;
            flex-shrink: 0;
        }

        .icon-revenue {
            background: #EAF4EC;
            color: var(--leaf-dark);
        }

        .icon-today {
            background: #FCF1DC;
            color: var(--amber-dark);
        }

        .icon-orders {
            background: #FDEDEA;
            color: var(--tomato-dark);
        }

        .icon-success {
            background: #EAF1F8;
            color: var(--sky);
        }

        /* ===== Panels ===== */
        .dashboard-layout {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 24px;
            margin-bottom: 24px;
        }

        .panel {
            background: var(--card);
            border-radius: 8px;
            padding: 24px;
            border: 1px solid var(--line);
            box-shadow: 0 1px 3px rgba(15,26,48,0.05);
        }

        .panel-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 12px;
            border-bottom: 2px solid var(--line);
            position: relative;
        }

            .panel-header::before {
                content: "";
                width: 10px;
                height: 10px;
                background: var(--leaf);
                display: inline-block;
                margin-right: 10px;
                transform: rotate(45deg);
            }

            .panel-header h3 {
                margin: 0;
                font-family: 'Anton', sans-serif;
                font-weight: 400;
                font-size: 18px;
                color: var(--forest-deep);
                text-transform: uppercase;
                display: flex;
                align-items: center;
                flex: 1;
            }

        /* ===== Ledger tables ===== */
        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead th {
            background: var(--paper);
            color: var(--muted);
            font-family: 'Inter', sans-serif;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-weight: 700;
            text-align: left;
            padding: 12px 14px;
            border-bottom: 2px solid var(--line);
            border-top: 1px solid var(--line);
        }

        tbody td {
            padding: 14px;
            border-bottom: 1px solid var(--line);
            font-size: 14px;
            vertical-align: middle;
        }

        tbody tr:last-child td {
            border-bottom: none;
        }

        tbody tr:nth-child(even) {
            background: rgba(63,143,92,0.045);
        }

        .td-name {
            font-weight: 600;
            color: var(--forest-deep);
        }

        .td-money {
            font-family: 'JetBrains Mono', monospace;
            font-weight: 700;
            color: var(--amber-dark);
            text-align: right;
        }

        .td-number {
            font-family: 'JetBrains Mono', monospace;
            text-align: center;
        }

        .empty-row {
            text-align: center;
            color: var(--muted);
            font-style: italic;
        }

        @@keyframes riseIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@media (prefers-reduced-motion: reduce) {
            .stat-card {
                animation: none;
            }
        }

        @@media (max-width: 1024px) {
            .dashboard-layout {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 640px) {
            .header-band {
                margin: -16px -16px 60px;
            }

            .filter-container {
                margin-top: -70px;
            }
        }
    </style>
}

<!-- Đầu trang kiểu mái hiên chợ -->
<div class="header-band">
    <div class="header-inner">
        <div>
            <p class="eyebrow">Thống kê &middot; Báo cáo</p>
            <h2 class="page-title">Bảng điều khiển</h2>
        </div>
        <span class="header-tag"><i class="fa-solid fa-store"></i>&nbsp; Bách Hóa Xanh &middot; Admin</span>
    </div>
    <svg class="awning-scallop" viewBox="0 0 400 18" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <defs>
            <pattern id="scallopPattern" width="24" height="18" patternUnits="userSpaceOnUse">
                <circle cx="12" cy="0" r="12" style="fill: var(--paper);" />
            </pattern>
        </defs>
        <rect width="100%" height="100%" style="fill: var(--forest);" />
        <rect width="100%" height="100%" fill="url(#scallopPattern)" />
    </svg>
</div>

<!-- Bộ lọc dữ liệu -->
<div class="filter-container">
    @using (Html.BeginForm("Index", "AdminDashboard", FormMethod.Get, new { id = "filterForm" }))
    {
        <div class="filter-panel">
            <div class="filter-group">
                <label>Thời gian thống kê</label>
                <select name="period" id="periodSelect" onchange="toggleCustomDates()">
                    <option value="thismonth" @(string.IsNullOrEmpty(Request["period"]) || Request["period"] == "thismonth" ? "selected" : "")>Tháng này</option>
                    <option value="today" @(Request["period"] == "today" ? "selected" : "")>Hôm nay</option>
                    <option value="7days" @(Request["period"] == "7days" ? "selected" : "")>7 ngày gần nhất</option>
                    <option value="lastmonth" @(Request["period"] == "lastmonth" ? "selected" : "")>Tháng trước</option>
                    <option value="custom" @(Request["period"] == "custom" ? "selected" : "")>Tùy chỉnh khoảng ngày...</option>
                </select>
            </div>

            <div class="filter-group">
                <label>Lọc theo Danh mục</label>
                @Html.DropDownList("categoryId", ViewBag.CategoryId as SelectList, "-- Tất cả danh mục --", new { @class = "form-control" })
            </div>

            <div class="filter-group custom-date" style="display: @(Request["period"] == "custom" ? "flex" : "none");">
                <label>Từ ngày</label>
                <input type="date" name="startDate" id="startDate" value="@(Request["startDate"] ?? "")" />
            </div>

            <div class="filter-group custom-date" style="display: @(Request["period"] == "custom" ? "flex" : "none");">
                <label>Đến ngày</label>
                <input type="date" name="endDate" id="endDate" value="@(Request["endDate"] ?? "")" />
            </div>

            <div style="display: flex; gap: 10px;">
                <button type="submit" class="btn-search"><i class="fa-solid fa-chart-line"></i> Áp dụng lọc</button>
            </div>
        </div>
    }
</div>

<!-- Khung Card Thống kê -->
<div class="cards-grid">
    <div class="stat-card">
        <div class="stat-info">
            <h5>Tổng doanh thu (All-time)</h5>
            <h3>@Model.TotalRevenue.ToString("N0") ₫</h3>
        </div>
        <div class="stat-icon icon-revenue"><i class="fa-solid fa-sack-dollar"></i></div>
    </div>

    <!-- Card này tự động thay đổi tên theo kỳ lọc -->
    <div class="stat-card">
        <div class="stat-info">
            <h5>Doanh thu kỳ lọc</h5>
            <h3>@Model.PeriodRevenue.ToString("N0") ₫</h3>
            <small style="color: var(--amber-dark); font-weight:700; font-size:11px;">@Model.CurrentPeriodInfo</small>
        </div>
        <div class="stat-icon icon-today"><i class="fa-solid fa-money-bill-trend-up"></i></div>
    </div>

    <div class="stat-card">
        <div class="stat-info">
            <h5>Đơn hàng kỳ lọc</h5>
            <h3>@Model.FilteredTotalOrders</h3>
            <small style="color: var(--muted); font-size:11px;">Thành công: <b>@Model.FilteredSuccessOrders</b></small>
        </div>
        <div class="stat-icon icon-orders"><i class="fa-solid fa-cart-flatbed"></i></div>
    </div>

    <div class="stat-card">
        <div class="stat-info">
            <h5>Tổng khách hàng</h5>
            <h3>@Model.TotalCustomers</h3>
        </div>
        <div class="stat-icon icon-success"><i class="fa-solid fa-users"></i></div>
    </div>
</div>

<!-- Layout Biểu đồ & Bảng -->
<div class="dashboard-layout">
    <!-- Cột Trái: Biểu đồ -->
    <div class="panel">
        <div class="panel-header">
            <h3>Biểu đồ doanh thu</h3>
        </div>
        <div style="position: relative; height: 320px; width: 100%;">
            <canvas id="revenueChart"></canvas>
        </div>
    </div>

    <!-- Cột Phải: Top Sản Phẩm -->
    <div class="panel">
        <div class="panel-header">
            <h3>Top Sản phẩm bán chạy</h3>
        </div>
        <div style="overflow-x: auto;">
            <table>
                <thead>
                    <tr>
                        <th>Tên sản phẩm</th>
                        <th style="text-align: center;">SL</th>
                        <th style="text-align: right;">Doanh thu</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.TopProducts != null && Model.TopProducts.Any())
                    {
                        foreach (var item in Model.TopProducts)
                        {
                            <tr>
                                <td class="td-name">@item.ProductName</td>
                                <td class="td-number">@item.QuantitySold</td>
                                <td class="td-money">@item.Revenue.ToString("N0") ₫</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="3" class="empty-row">Chưa có dữ liệu</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Danh mục đóng góp -->
<div class="panel" style="margin-bottom: 40px;">
    <div class="panel-header">
        <h3>Tỷ trọng doanh thu theo danh mục</h3>
    </div>
    <div style="overflow-x: auto;">
        <table>
            <thead>
                <tr>
                    <th>Tên danh mục</th>
                    <th style="text-align: right;">Tổng doanh thu mang lại</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.CategoryRevenue != null && Model.CategoryRevenue.Any())
                {
                    foreach (var item in Model.CategoryRevenue)
                    {
                        <tr>
                            <td class="td-name">@item.CategoryName</td>
                            <td class="td-money">@item.Revenue.ToString("N0") ₫</td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="2" class="empty-row">Chưa có dữ liệu</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Xử lý ẩn hiện ô chọn ngày tùy chỉnh
        function toggleCustomDates() {
            var period = document.getElementById("periodSelect").value;
            var customDates = document.querySelectorAll(".custom-date");
            if (period === "custom") {
                customDates.forEach(el => el.style.display = "flex");
            } else {
                customDates.forEach(el => el.style.display = "none");
            }
        }

        // Vẽ biểu đồ Chart.js
        const labels = [];
        const values = [];

        @if (Model.RevenueChart != null)
        {
            foreach (var item in Model.RevenueChart)
            {
                <text>
                labels.push("@Html.Raw(item.Label)");
                values.push(@item.Revenue);
                </text>
            }
        }

        const ctx = document.getElementById("revenueChart").getContext("2d");

        // Gradient xanh lá cho biểu đồ, đồng bộ với bảng màu "chợ xanh"
        let gradient = ctx.createLinearGradient(0, 0, 0, 320);
        gradient.addColorStop(0, 'rgba(63, 143, 92, 0.25)');
        gradient.addColorStop(1, 'rgba(63, 143, 92, 0)');

        new Chart(ctx, {
            type: "line",
            data: {
                labels: labels,
                datasets: [{
                    label: "Doanh thu (VNĐ)",
                    data: values,
                    borderColor: "#1F6B3F",
                    backgroundColor: gradient,
                    borderWidth: 3,
                    pointBackgroundColor: "#fff",
                    pointBorderColor: "#1F6B3F",
                    pointBorderWidth: 2,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    fill: true,
                    tension: 0.3
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: '#163B2E',
                        padding: 12,
                        titleFont: { family: 'Inter', size: 13 },
                        bodyFont: { family: 'JetBrains Mono', size: 14, weight: 'bold' },
                        callbacks: {
                            label: function(context) {
                                let label = context.dataset.label || '';
                                if (label) {
                                    label += ': ';
                                }
                                if (context.parsed.y !== null) {
                                    label += new Intl.NumberFormat('vi-VN').format(context.parsed.y) + ' ₫';
                                }
                                return label;
                            }
                        }
                    }
                },

                scales: {
                    x: { grid: { display: false } },
                    y: {
                        beginAtZero: true,
                        grid: { borderDash: [4, 4], color: '#DBD5C2' },
                        ticks: {
                            callback: function(value) {
                                return new Intl.NumberFormat('vi-VN').format(value);
                            }
                        }
                    }
                }
            }
        });
    </script>
}
