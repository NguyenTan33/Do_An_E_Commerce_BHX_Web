@model IEnumerable<Do_An_E_Commerce_BHX.Models.Entities.Promotion>

@{
    ViewData["Title"] = "Quản lý Khuyến mãi";
    ViewData["Subtitle"] = "Danh sách các mã giảm giá và chương trình ưu đãi";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

@section Styles {
    <style>
        :root {
            --navy: #16233F;
            --navy-deep: #0F1A30;
            --paper: #FAF8F4;
            --ink: #22262E;
            --muted: #6B7280;
            --line: #E5E1D8;
            --amber: #E2792B;
            --green: #2F8F5B;
            --red: #C4453A;
        }

        .header, .filter-container, .table-wrap {
            width: 100%;
            max-width: 100% !important;
            margin-left: 0 !important;
            margin-right: 0 !important;
        }

        .header {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 24px;
            border-bottom: 3px solid var(--navy);
            padding-bottom: 16px;
        }

        .eyebrow {
            font-family: 'JetBrains Mono', monospace;
            font-size: 12px;
            letter-spacing: 0.18em;
            color: var(--muted);
            text-transform: uppercase;
            margin: 0 0 6px;
        }

        h2 {
            font-family: 'Oswald', sans-serif;
            font-weight: 700;
            font-size: 30px;
            letter-spacing: 0.01em;
            color: var(--navy-deep);
            margin: 0;
            text-transform: uppercase;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .count-badge {
            font-family: 'JetBrains Mono', monospace;
            font-size: 13px;
            background: var(--navy);
            color: #fff;
            padding: 6px 14px;
            border-radius: 3px;
            letter-spacing: 0.04em;
        }

        .btn-add {
            font-family: 'Oswald', sans-serif;
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            background: var(--amber);
            color: #fff;
            padding: 9px 16px;
            border-radius: 4px;
            text-decoration: none;
            transition: opacity 0.15s ease;
        }

            .btn-add:hover {
                opacity: 0.9;
            }

        .filter-panel {
            background: #fff;
            border-radius: 8px;
            padding: 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,.08);
            border: 1px solid var(--line);
            display: flex;
            gap: 18px;
            align-items: flex-end;
            margin-bottom: 20px;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
            min-width: 200px;
            flex: 1;
        }

            .filter-group label {
                font-weight: 600;
                font-size: 13px;
                margin-bottom: 6px;
                color: var(--navy-deep);
            }

            .filter-group input, .filter-group select {
                height: 40px;
                border: 1px solid var(--line);
                border-radius: 6px;
                padding: 0 12px;
                font-family: 'Inter', sans-serif;
                font-size: 14px;
                outline: none;
            }

                .filter-group input:focus, .filter-group select:focus {
                    border-color: var(--navy);
                }

        .btn-search {
            height: 40px;
            padding: 0 22px;
            border: none;
            border-radius: 6px;
            background: var(--navy);
            color: #fff;
            font-family: 'Oswald', sans-serif;
            font-size: 13px;
            text-transform: uppercase;
            cursor: pointer;
        }

        .btn-reset {
            height: 40px;
            padding: 0 22px;
            border-radius: 6px;
            text-decoration: none;
            background: #E5E1D8;
            color: var(--ink);
            font-family: 'Oswald', sans-serif;
            font-size: 13px;
            text-transform: uppercase;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-left: 10px;
        }

        table {
            border-collapse: collapse;
            width: 100%;
        }

        .table-wrap {
            background: #fff;
            border-radius: 6px;
            box-shadow: 0 1px 3px rgba(15,26,48,0.08);
            border: 1px solid var(--line);
            overflow: hidden;
        }

        thead th {
            background: var(--navy);
            color: #fff;
            font-family: 'Oswald', sans-serif;
            font-size: 13px;
            text-transform: uppercase;
            text-align: left;
            padding: 14px 16px;
        }

        tbody td {
            padding: 13px 16px;
            border-bottom: 1px solid var(--line);
            font-size: 14px;
            vertical-align: middle;
        }

        tbody tr:hover {
            background: #F3F0E9;
        }

        .code-cell {
            font-family: 'JetBrains Mono', monospace;
            font-size: 16px;
            font-weight: 700;
            color: var(--amber);
            letter-spacing: 1px;
        }

        .date-cell {
            font-family: 'JetBrains Mono', monospace;
            font-size: 13px;
            color: var(--muted);
        }

        .money-cell {
            font-family: 'JetBrains Mono', monospace;
            font-weight: 600;
            color: var(--navy-deep);
        }

        .badge-tag {
            display: inline-block;
            font-size: 11px;
            padding: 3px 8px;
            border-radius: 4px;
            font-weight: 600;
        }

        .bg-active {
            background: #DEF7EC;
            color: var(--green);
        }

        .bg-expired {
            background: #FDE8E8;
            color: var(--red);
        }

        .bg-disabled {
            background: #E5E7EB;
            color: var(--muted);
        }

        .action-cell {
            white-space: nowrap;
            text-align: right;
        }

            .action-cell form {
                display: inline-block;
                margin: 0;
            }

        .icon-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 30px;
            height: 30px;
            border-radius: 4px;
            border: 1.5px solid var(--line);
            background: #fff;
            cursor: pointer;
            margin-left: 6px;
        }

            .icon-btn svg {
                width: 15px;
                height: 15px;
            }

            .icon-btn.edit {
                color: var(--navy);
            }

                .icon-btn.edit:hover {
                    background: #EEF1F6;
                }

            .icon-btn.delete {
                color: var(--red);
            }

                .icon-btn.delete:hover {
                    background: #FBEAE8;
                }

        /* Modal */
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(15,26,48,0.55);
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

            .modal-overlay.active {
                display: flex;
            }

        .modal-box {
            background: #fff;
            border-radius: 6px;
            padding: 28px;
            max-width: 400px;
            width: 90%;
        }

        .modal-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            margin-top: 20px;
        }

            .modal-actions button {
                padding: 10px 18px;
                border-radius: 4px;
                border: none;
                font-weight: 600;
                cursor: pointer;
                text-transform: uppercase;
                font-family: 'Oswald', sans-serif;
            }

        .modal-cancel {
            border: 1.5px solid var(--line);
            background: transparent;
        }

        .modal-delete {
            background: var(--red);
            color: #fff;
        }
    </style>
}

<div class="header">
    <div>
        <p class="eyebrow">Marketing &middot; Ưu đãi</p>
        <h2>Danh sách Khuyến mãi</h2>
    </div>
    <div class="header-right">
        <span class="count-badge">@(Model?.Count() ?? 0) Mã</span>
        <a href="@Url.Action("ThemPromotion", "ManagePromotion")" class="btn-add">+ Thêm mã khuyến mãi</a>
    </div>
</div>

<div class="filter-container">
    @using (Html.BeginForm("Index", "ManagePromotion", FormMethod.Get))
    {
        <div class="filter-panel">
            <div class="filter-group">
                <label>Mã giảm giá (Code)</label>
                <input type="text" name="tuKhoa" value="@Request["tuKhoa"]" placeholder="Nhập mã CODE..." style="text-transform: uppercase;" />
            </div>

            <div class="filter-group">
                <label>Trạng thái</label>
                <select name="trangThai">
                    <option value="">-- Tất cả trạng thái --</option>
                    <option value="true" @(Request["trangThai"] == "true" ? "selected" : "")>Đang hiệu lực</option>
                    <option value="false" @(Request["trangThai"] == "false" ? "selected" : "")>Vô hiệu hóa</option>
                </select>
            </div>

            <div>
                <button type="submit" class="btn-search">🔍 Tìm kiếm</button>
                <a href="@Url.Action("Index")" class="btn-reset">Đặt lại</a>
            </div>
        </div>
    }
</div>

<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>Mã giảm giá</th>
                <th>Mức giảm</th>
                <th>Hiệu lực từ</th>
                <th>Hết hạn vào</th>
                <th>Ngày tạo</th>
                <th>Trạng thái</th>
                <th style="text-align:right;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    bool isExpired = item.ExpiryDate < DateTime.Now;

                    <tr>
                        <td class="code-cell">@item.Code</td>
                        <td class="money-cell" style="color: var(--red);">
                            @if (item.percentDiscount > 0)
                            {
                                <span>- @item.percentDiscount.ToString("0.##") %</span>
                            }
                            else if (item.DiscountValue > 0)
                            {
                                <span>- @item.DiscountValue.ToString("N0") ₫</span>
                            }
                            else
                            {
                                <span style="color: var(--muted);">0 ₫</span>
                            }
                        </td>
                        <td class="date-cell">@item.EffectiveDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="date-cell">@item.ExpiryDate.ToString("dd/MM/yyyy HH:mm")</td>
                        <td class="date-cell">@item.DateCreated.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (!item.IsActive)
                            {
                                <span class="badge-tag bg-disabled">Vô hiệu hóa</span>
                            }
                            else if (isExpired)
                            {
                                <span class="badge-tag bg-expired">Đã hết hạn</span>
                            }
                            else
                            {
                                <span class="badge-tag bg-active">Đang hiệu lực</span>
                            }
                        </td>
                        <td class="action-cell">
                            <!-- Nút Sửa -->
                            <a href="@Url.Action("SuaPromotion", "ManagePromotion", new { id = item.Id })" class="icon-btn edit" title="Sửa mã">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                </svg>
                            </a>

                            <!-- Nút Xóa -->
                            @using (Html.BeginForm("XoaPromotion", "ManagePromotion", FormMethod.Post, new { id = "formDelete_" + item.Id }))
                            {
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="button" class="icon-btn delete" title="Xóa mã"
                                        onclick="openDeleteModal('@item.Id', '@item.Code')">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="3 6 5 6 21 6"></polyline>
                                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                                        <path d="M10 11v6"></path>
                                        <path d="M14 11v6"></path>
                                        <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"></path>
                                    </svg>
                                </button>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="7" class="empty-state">Chưa có mã khuyến mãi nào trong hệ thống.</td></tr>
            }
        </tbody>
    </table>
</div>

<div class="modal-overlay" id="deleteModal">
    <div class="modal-box">
        <h3 style="color: var(--red);">Xác nhận xóa mã</h3>
        <p style="font-size:14px; color:var(--muted); margin-bottom:20px;">
            Bạn có chắc chắn muốn xóa mã khuyến mãi <strong id="deletePromoCode" style="color:var(--ink); font-family: 'JetBrains Mono'; font-size: 16px;"></strong>?
        </p>
        <div class="modal-actions">
            <button type="button" class="modal-cancel" onclick="closeDeleteModal()">Hủy</button>
            <button type="button" class="modal-delete" onclick="confirmDelete()">Xóa mã</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let promoIdToDelete = null;

        function openDeleteModal(id, code) {
            promoIdToDelete = id;
            document.getElementById('deletePromoCode').textContent = code;
            document.getElementById('deleteModal').classList.add('active');
        }

        function closeDeleteModal() {
            document.getElementById('deleteModal').classList.remove('active');
        }

        function confirmDelete() {
            if (promoIdToDelete) {
                document.getElementById('formDelete_' + promoIdToDelete).submit();
            }
        }

        document.getElementById('deleteModal').addEventListener('click', function (e) {
            if (e.target === this) closeDeleteModal();
        });
    </script>
}