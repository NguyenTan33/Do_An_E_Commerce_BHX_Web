@model IEnumerable<Do_An_E_Commerce_BHX.Areas.Admin.Controllers.UserViewModel>

@{
    ViewData["Title"] = "Quản lý người dùng";
    ViewData["Subtitle"] = "Danh sách tài khoản và phân quyền hệ thống";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

@section Styles {
    <style>
        :root {
            --navy: #16233F;
            --navy-deep: #0F1A30;
            --paper: #FAF8F4;
            --ink: #22262E;
            --muted: #6B7280;
            --line: #E5E1D8;
            --amber: #E2792B;
            --green: #2F8F5B;
            --red: #C4453A;
        }

        /* Khung tràn màn hình */
        .header,
        .filter-container,
        .table-wrap {
            width: 100%;
            max-width: 100% !important;
            margin-left: 0 !important;
            margin-right: 0 !important;
        }

        .header {
            display: flex;
            align-items: flex-end;
            justify-content: space-between;
            margin-bottom: 24px;
            border-bottom: 3px solid var(--navy);
            padding-bottom: 16px;
        }

        .eyebrow {
            font-family: 'JetBrains Mono', monospace;
            font-size: 12px;
            letter-spacing: 0.18em;
            color: var(--muted);
            text-transform: uppercase;
            margin: 0 0 6px;
        }

        h2 {
            font-family: 'Oswald', sans-serif;
            font-weight: 700;
            font-size: 30px;
            letter-spacing: 0.01em;
            color: var(--navy-deep);
            margin: 0;
            text-transform: uppercase;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .count-badge {
            font-family: 'JetBrains Mono', monospace;
            font-size: 13px;
            background: var(--navy);
            color: #fff;
            padding: 6px 14px;
            border-radius: 3px;
            letter-spacing: 0.04em;
        }

        .btn-add {
            font-family: 'Oswald', sans-serif;
            font-size: 13px;
            font-weight: 600;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            background: var(--amber);
            color: #fff;
            padding: 9px 16px;
            border-radius: 4px;
            text-decoration: none;
            transition: opacity 0.15s ease;
        }

            .btn-add:hover {
                opacity: 0.9;
            }

        /* Filter Panel */
        .filter-container {
            margin-bottom: 20px;
        }

        .filter-panel {
            background: #fff;
            border-radius: 8px;
            padding: 20px;
            box-shadow: 0 2px 8px rgba(0,0,0,.08);
            border: 1px solid var(--line);
            display: flex;
            gap: 18px;
            align-items: flex-end;
            flex-wrap: wrap;
        }

        .filter-group {
            display: flex;
            flex-direction: column;
            min-width: 220px;
            flex: 1;
        }

            .filter-group label {
                font-weight: 600;
                font-size: 13px;
                margin-bottom: 6px;
                color: var(--navy-deep);
            }

            .filter-group input,
            .filter-group select {
                height: 40px;
                border: 1px solid var(--line);
                border-radius: 6px;
                padding: 0 12px;
                font-family: 'Inter', sans-serif;
                font-size: 14px;
                outline: none;
                transition: border-color 0.15s ease;
            }

                .filter-group input:focus, .filter-group select:focus {
                    border-color: var(--navy);
                }

        .filter-button {
            display: flex;
            gap: 10px;
        }

        .btn-search {
            height: 40px;
            padding: 0 22px;
            border: none;
            border-radius: 6px;
            background: var(--navy);
            color: #fff;
            font-family: 'Oswald', sans-serif;
            font-size: 13px;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            cursor: pointer;
        }

        .btn-reset {
            height: 40px;
            padding: 0 22px;
            border-radius: 6px;
            text-decoration: none;
            background: #E5E1D8;
            color: var(--ink);
            font-family: 'Oswald', sans-serif;
            font-size: 13px;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        /* Table */
        .table-wrap {
            background: #fff;
            border-radius: 6px;
            overflow: hidden;
            box-shadow: 0 1px 3px rgba(15,26,48,0.08), 0 8px 24px rgba(15,26,48,0.06);
            border: 1px solid var(--line);
        }

        table {
            border-collapse: collapse;
            width: 100%;
        }

        thead th {
            position: sticky;
            top: 0;
            background: var(--navy);
            color: #fff;
            font-family: 'Oswald', sans-serif;
            font-weight: 500;
            font-size: 13px;
            letter-spacing: 0.06em;
            text-transform: uppercase;
            text-align: left;
            padding: 14px 16px;
        }

        tbody td {
            padding: 13px 16px;
            border-bottom: 1px solid var(--line);
            font-size: 14px;
            vertical-align: middle;
        }

        tbody tr:hover {
            background: #F3F0E9;
        }

        tbody tr:last-child td {
            border-bottom: none;
        }

        .user-info {
            display: flex;
            flex-direction: column;
            gap: 3px;
        }

        .user-name {
            font-weight: 600;
            color: var(--navy-deep);
            font-size: 15px;
        }

        .user-email {
            font-size: 13px;
            color: var(--muted);
            font-family: 'JetBrains Mono', monospace;
        }

        .badge-tag {
            display: inline-block;
            font-size: 11px;
            padding: 3px 8px;
            border-radius: 4px;
            font-weight: 600;
            margin-right: 4px;
        }

        .bg-admin {
            background: #FDE8E8;
            color: var(--red);
        }

        .bg-user {
            background: #DEF7EC;
            color: var(--green);
        }

        .bg-locked {
            background: #F3F4F6;
            color: var(--muted);
            text-decoration: line-through;
        }

        .action-cell {
            white-space: nowrap;
            text-align: right;
        }

            .action-cell form {
                display: inline-block;
                margin: 0;
            }

        .icon-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 30px;
            height: 30px;
            border-radius: 4px;
            border: 1.5px solid var(--line);
            background: #fff;
            cursor: pointer;
            text-decoration: none;
            margin-left: 6px;
            transition: all 0.15s ease;
        }

            .icon-btn svg {
                width: 15px;
                height: 15px;
            }

            .icon-btn.key {
                color: var(--amber);
            }

                .icon-btn.key:hover {
                    border-color: var(--amber);
                    background: #FEF3C7;
                }

            .icon-btn.edit {
                color: var(--navy);
            }

                .icon-btn.edit:hover {
                    border-color: var(--navy);
                    background: #EEF1F6;
                }

            .icon-btn.lock {
                color: var(--muted);
            }

                .icon-btn.lock:hover {
                    border-color: var(--ink);
                    background: #E5E7EB;
                    color: var(--ink);
                }

            .icon-btn.delete {
                color: var(--red);
            }

                .icon-btn.delete:hover {
                    border-color: var(--red);
                    background: #FBEAE8;
                }

        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--muted);
        }

        /* Modals */
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(15,26,48,0.55);
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }

            .modal-overlay.active {
                display: flex;
            }

        .modal-box {
            background: #fff;
            border-radius: 6px;
            padding: 28px;
            max-width: 400px;
            width: 90%;
            box-shadow: 0 20px 50px rgba(15,26,48,0.3);
        }

            .modal-box h3 {
                font-family: 'Oswald', sans-serif;
                font-size: 18px;
                text-transform: uppercase;
                color: var(--navy-deep);
                margin: 0 0 14px;
            }

        .modal-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            margin-top: 20px;
        }

            .modal-actions button {
                font-family: 'Oswald', sans-serif;
                font-size: 13px;
                font-weight: 600;
                text-transform: uppercase;
                padding: 10px 18px;
                border-radius: 4px;
                border: none;
                cursor: pointer;
            }

        .modal-cancel {
            background: transparent;
            border: 1.5px solid var(--line) !important;
            color: var(--muted);
        }

        .modal-confirm {
            background: var(--navy);
            color: #fff;
        }

        .modal-delete {
            background: var(--red);
            color: #fff;
        }
    </style>
}

<div class="header">
    <div>
        <p class="eyebrow">Hệ thống &middot; Con người</p>
        <h2>Danh sách người dùng</h2>
    </div>
    <div class="header-right">
        <span class="count-badge">@(Model?.Count() ?? 0) User</span>
        <a href="@Url.Action("ThemUser", "ManageUser")" class="btn-add">+ Thêm tài khoản</a>
    </div>
</div>

<!-- Cảnh báo lỗi (Nếu admin tự xóa chính mình) -->
@if (TempData["Error"] != null)
{
    <div style="background: #FDE8E8; color: var(--red); padding: 12px 16px; border-radius: 6px; margin-bottom: 20px; font-weight: 500; border: 1px solid #FBC4C4;">
        ⚠️ @TempData["Error"]
    </div>
}

<!-- Bộ lọc tìm kiếm -->
<div class="filter-container">
    @using (Html.BeginForm("Index", "ManageUser", FormMethod.Get))
    {
        <div class="filter-panel">
            <div class="filter-group">
                <label>Từ khóa tìm kiếm</label>
                <input type="text" name="tuKhoa" value="@Request["tuKhoa"]" placeholder="Tên, Email hoặc Username..." />
            </div>

            <div class="filter-group">
                <label>Nhóm quyền (Role)</label>
                @Html.DropDownList("roleFilter", ViewBag.RolesList as SelectList, "-- Tất cả quyền --", new { @class = "form-control" })
            </div>

            <div class="filter-button">
                <button type="submit" class="btn-search">🔍 Lọc dữ liệu</button>
                <a href="@Url.Action("Index")" class="btn-reset">Đặt lại</a>
            </div>
        </div>
    }
</div>

<!-- Bảng danh sách User -->
<div class="table-wrap">
    <table>
        <thead>
            <tr>
                <th>Người dùng</th>
                <th>Số điện thoại</th>
                <th>Phân quyền</th>
                <th>Trạng thái</th>
                <th style="text-align:right;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <div class="user-info">
                                <span class="user-name">@user.FullName</span>
                                <span class="user-email">@user.Email</span>
                            </div>
                        </td>
                        <td style="font-family:'JetBrains Mono'; font-size: 13.5px;">
                            @(string.IsNullOrEmpty(user.PhoneNumber) ? "N/A" : user.PhoneNumber)
                        </td>
                        <td>
                            @if (user.Roles != null && user.Roles.Any())
                            {
                                foreach (var role in user.Roles)
                                {
                                    <span class="badge-tag @(role == "Admin" ? "bg-admin" : "bg-user")">@role</span>
                                }
                            }
                            else
                            {
                                <span style="color:var(--muted); font-size:12px;">Chưa phân quyền</span>
                            }
                        </td>
                        <td>
                            @if (user.IsLocked)
                            {
                                <span class="badge-tag bg-locked">Đang bị khóa 🔒</span>
                            }
                            else
                            {
                                <span class="badge-tag bg-user">Đang hoạt động ✅</span>
                            }
                        </td>
                        <td class="action-cell">
                            <!-- Nút Reset Mật khẩu -->
                            <button type="button" class="icon-btn key" title="Đặt lại mật khẩu"
                                    onclick="openResetPassModal('@user.Id', '@user.Email')">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"></path>
                                </svg>
                            </button>

                            <!-- Nút Khóa / Mở Khóa -->
                            @using (Html.BeginForm("ToggleLock", "ManageUser", FormMethod.Post))
                            {
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@user.Id" />
                                <button type="submit" class="icon-btn lock" title="@(user.IsLocked ? "Mở khóa tài khoản" : "Khóa tài khoản")"
                                        onclick="return confirm('Bạn có chắc muốn @(user.IsLocked ? "MỞ KHÓA" : "KHÓA") tài khoản này không?');">
                                    @if (user.IsLocked)
                                    {
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 9.9-1"></path></svg>
                                    }
                                    else
                                    {
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                                    }
                                </button>
                            }

                            <!-- Nút Sửa -->
                            <a href="@Url.Action("SuaUser", "ManageUser", new { id = user.Id })" class="icon-btn edit" title="Sửa thông tin">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                                </svg>
                            </a>

                            <!-- Nút Xóa -->
                            @using (Html.BeginForm("XoaUser", "ManageUser", FormMethod.Post, new { id = "formDelete_" + user.Id }))
                            {
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@user.Id" />
                                <button type="button" class="icon-btn delete" title="Xóa tài khoản"
                                        onclick="openDeleteModal('@user.Id', '@user.Email')">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                        <polyline points="3 6 5 6 21 6"></polyline>
                                        <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"></path>
                                        <path d="M10 11v6"></path>
                                        <path d="M14 11v6"></path>
                                        <path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"></path>
                                    </svg>
                                </button>
                            }
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="5" class="empty-state">Chưa có người dùng nào phù hợp với tìm kiếm.</td></tr>
            }
        </tbody>
    </table>
</div>

<!-- ================= MODALS ================= -->
<!-- Modal Reset Password (Gửi AJAX) -->
<div class="modal-overlay" id="resetPassModal">
    <div class="modal-box">
        <h3>Đặt lại mật khẩu</h3>
        <p style="font-size: 13.5px; color: var(--muted); margin-bottom: 16px;">
            Nhập mật khẩu mới cho tài khoản: <strong id="resetUserEmail" style="color:var(--navy-deep);"></strong>
        </p>

        @Html.AntiForgeryToken() <!-- Lấy Token cho AJAX -->
        <input type="hidden" id="resetUserId" />

        <div class="filter-group" style="width: 100%;">
            <label>Mật khẩu mới</label>
            <input type="password" id="newPassword" placeholder="Nhập ít nhất 6 ký tự..." />
        </div>

        <!-- Hiển thị thông báo AJAX -->
        <div id="resetMessage" style="margin-top: 10px; font-size: 13px; font-weight: 500;"></div>

        <div class="modal-actions">
            <button type="button" class="modal-cancel" onclick="closeModal('resetPassModal')">Đóng</button>
            <button type="button" class="modal-confirm" onclick="submitResetPassword()">Cập nhật mật khẩu</button>
        </div>
    </div>
</div>

<!-- Modal Xác Nhận Xóa -->
<div class="modal-overlay" id="deleteModal">
    <div class="modal-box">
        <h3 style="color: var(--red);">Xác nhận xóa tài khoản</h3>
        <p style="font-size:14px; color:var(--muted); margin-bottom:20px;">
            Hành động này sẽ xóa vĩnh viễn tài khoản <strong id="deleteUserEmail" style="color:var(--ink);"></strong>. Bạn có chắc chắn không?
        </p>
        <div class="modal-actions">
            <button type="button" class="modal-cancel" onclick="closeModal('deleteModal')">Hủy</button>
            <button type="button" class="modal-delete" onclick="confirmDelete()">Xóa tài khoản</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // --- XỬ LÝ XÓA TÀI KHOẢN ---
        let userIdToDelete = null;

        function openDeleteModal(id, email) {
            userIdToDelete = id;
            document.getElementById('deleteUserEmail').textContent = email;
            document.getElementById('deleteModal').classList.add('active');
        }

        function confirmDelete() {
            if (userIdToDelete) {
                document.getElementById('formDelete_' + userIdToDelete).submit();
            }
        }

        // --- XỬ LÝ ĐẶT LẠI MẬT KHẨU (AJAX) ---
        function openResetPassModal(id, email) {
            document.getElementById('resetUserId').value = id;
            document.getElementById('resetUserEmail').textContent = email;
            document.getElementById('newPassword').value = '';
            document.getElementById('resetMessage').textContent = '';
            document.getElementById('resetPassModal').classList.add('active');
        }

        function submitResetPassword() {
            const userId = document.getElementById('resetUserId').value;
            const newPassword = document.getElementById('newPassword').value;
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
            const msgBox = document.getElementById('resetMessage');

            if (!newPassword || newPassword.length < 6) {
                msgBox.style.color = 'var(--red)';
                msgBox.textContent = 'Mật khẩu phải có ít nhất 6 ký tự!';
                return;
            }

            msgBox.style.color = 'var(--amber)';
            msgBox.textContent = 'Đang xử lý...';

            // Gửi AJAX Form Data
            const formData = new FormData();
            formData.append('userId', userId);
            formData.append('newPassword', newPassword);
            formData.append('__RequestVerificationToken', token);

            fetch('@Url.Action("ResetPassword", "ManageUser")', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    msgBox.style.color = 'var(--green)';
                    msgBox.textContent = '✅ Đặt lại mật khẩu thành công!';
                    setTimeout(() => closeModal('resetPassModal'), 2000);
                } else {
                    msgBox.style.color = 'var(--red)';
                    msgBox.textContent = '❌ Lỗi: ' + data.message;
                }
            })
            .catch(error => {
                msgBox.style.color = 'var(--red)';
                msgBox.textContent = 'Đã xảy ra lỗi kết nối!';
            });
        }

        // --- ĐÓNG MODAL CHUNG ---
        function closeModal(modalId) {
            document.getElementById(modalId).classList.remove('active');
        }

        document.querySelectorAll('.modal-overlay').forEach(modal => {
            modal.addEventListener('click', function (e) {
                if (e.target === this) closeModal(this.id);
            });
        });
    </script>
}