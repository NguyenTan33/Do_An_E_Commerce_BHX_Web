
@model Do_An_E_Commerce_BHX.Models.Entities.Product

@{
    ViewBag.Title = "Thêm Sản Phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>Thêm sản phẩm</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --navy: #16233F;
            --navy-deep: #0F1A30;
            --paper: #FAF8F4;
            --ink: #22262E;
            --muted: #6B7280;
            --line: #E5E1D8;
            --amber: #E2792B;
            --green: #2F8F5B;
            --red: #C4453A;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            padding: 40px 32px 60px;
            background: var(--paper);
            background-image: radial-gradient(circle at 1px 1px, rgba(22,35,63,0.06) 1px, transparent 0);
            background-size: 22px 22px;
            font-family: 'Inter', Arial, sans-serif;
            color: var(--ink);
        }

        .header {
            max-width: 560px;
            margin: 0 auto 24px;
            border-bottom: 3px solid var(--navy);
            padding-bottom: 16px;
        }

        .eyebrow {
            font-family: 'JetBrains Mono', monospace;
            font-size: 12px;
            letter-spacing: 0.18em;
            color: var(--muted);
            text-transform: uppercase;
            margin: 0 0 6px;
        }

        h2 {
            font-family: 'Oswald', sans-serif;
            font-weight: 700;
            font-size: 28px;
            letter-spacing: 0.01em;
            color: var(--navy-deep);
            margin: 0;
            text-transform: uppercase;
        }

        .back-link {
            display: inline-block;
            margin-top: 10px;
            font-size: 13px;
            color: var(--muted);
            text-decoration: none;
        }

            .back-link:hover {
                color: var(--navy);
            }

        .form-card {
            max-width: 560px;
            margin: 0 auto;
            background: #fff;
            border-radius: 6px;
            padding: 32px;
            box-shadow: 0 1px 3px rgba(15,26,48,0.08), 0 8px 24px rgba(15,26,48,0.06);
        }

        .field {
            margin-bottom: 20px;
        }

            .field label {
                display: block;
                font-family: 'Oswald', sans-serif;
                font-size: 12px;
                font-weight: 600;
                letter-spacing: 0.06em;
                text-transform: uppercase;
                color: var(--navy-deep);
                margin-bottom: 7px;
            }

            .field input {
                width: 100%;
                padding: 11px 14px;
                font-family: 'Inter', sans-serif;
                font-size: 14px;
                border: 1.5px solid var(--line);
                border-radius: 4px;
                background: var(--paper);
                outline: none;
                transition: border-color 0.15s ease, box-shadow 0.15s ease;
            }

                .field input:focus {
                    border-color: var(--navy);
                    box-shadow: 0 0 0 3px rgba(22,35,63,0.08);
                    background: #fff;
                }

            .field.barcode input,
            .field.price input {
                font-family: 'JetBrains Mono', monospace;
            }

            .field .hint {
                font-size: 12px;
                color: var(--muted);
                margin-top: 5px;
            }

        .field-validation-error {
            display: block;
            font-size: 12px;
            color: var(--red);
            margin-top: 5px;
        }

        .input-validation-error {
            border-color: var(--red) !important;
        }

        .validation-summary-errors {
            background: #FBEAE8;
            border: 1px solid var(--red);
            color: var(--red);
            border-radius: 4px;
            padding: 12px 16px;
            margin-bottom: 20px;
            font-size: 13px;
        }

            .validation-summary-errors ul {
                margin: 0;
                padding-left: 18px;
            }

        .actions {
            display: flex;
            gap: 12px;
            margin-top: 28px;
        }

        .btn {
            font-family: 'Oswald', sans-serif;
            font-size: 14px;
            font-weight: 600;
            letter-spacing: 0.04em;
            text-transform: uppercase;
            padding: 12px 22px;
            border-radius: 4px;
            border: none;
            cursor: pointer;
            transition: opacity 0.15s ease, transform 0.1s ease;
        }

            .btn:active {
                transform: scale(0.98);
            }

        .btn-primary {
            background: var(--navy);
            color: #fff;
        }

            .btn-primary:hover {
                opacity: 0.9;
            }

        .btn-secondary {
            background: transparent;
            color: var(--muted);
            border: 1.5px solid var(--line);
            text-decoration: none;
            display: inline-flex;
            align-items: center;
        }

            .btn-secondary:hover {
                border-color: var(--muted);
                color: var(--ink);
            }
    </style>
</head>
<body>

    <div class="header">
        <p class="eyebrow">Quản lý kho &middot; Bán lẻ</p>
        <h2>Thêm sản phẩm mới</h2>
        @Html.ActionLink("← Quay lại danh sách sản phẩm", "Index", "Products", null, new { @class = "back-link" })
    </div>

    <div class="form-card">
        <div class="form-card">
            @using (Html.BeginForm("ThemSP", "ManageProduct", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(false)

                <div class="field">
                    <label>Tên sản phẩm</label>
                    @Html.TextBoxFor(m => m.Name, new { placeholder = "VD: Coca Cola 390ml" })
                    @Html.ValidationMessageFor(m => m.Name)
                </div>

                <div class="field barcode">
                    <label>Mã vạch</label>
                    @Html.TextBoxFor(m => m.Barcode, new { placeholder = "8938505974194" })
                    @Html.ValidationMessageFor(m => m.Barcode)
                </div>

                <div class="field price">
                    <label>Giá bán (VNĐ)</label>
                    @Html.TextBoxFor(m => m.Price, new
                    {
                        type = "number",
                        min = "0",
                        step = "1000",
                        placeholder = "10000"
                    })
                    @Html.ValidationMessageFor(m => m.Price)
                </div>

                <div class="field">
                    <label>Số lượng tồn kho</label>
                    @Html.TextBoxFor(m => m.Quantity, new
                    {
                        type = "number",
                        min = "0",
                        placeholder = "100"
                    })
                    @Html.ValidationMessageFor(m => m.Quantity)
                </div>

                <div class="field">
                    <label>Mô tả</label>
                    @Html.TextAreaFor(m => m.Description, new
                    {
                        rows = "4",
                        placeholder = "Nhập mô tả sản phẩm...",
                        style = "width:100%;padding:12px;border:1.5px solid #E5E1D8;border-radius:4px;background:#FAF8F4;"
                    })
                </div>

                <div class="field">
                    <label>Ảnh sản phẩm</label>
                    @Html.TextBoxFor(m => m.URLImage, new
                    {
                        placeholder = "coca.jpg"
                    })
                </div>

                <div class="field">
                    <label>Danh mục</label>
                    @Html.DropDownListFor(m => m.CategoryId,
                        ViewBag.CategoryId as SelectList,
                        "-- Chọn danh mục --",
                        new
                        {
                            @class = "form-control",
                            style = "width:100%;padding:11px 14px;border:1.5px solid #E5E1D8;border-radius:4px;background:#FAF8F4;"
                        })
                    @Html.ValidationMessageFor(m => m.CategoryId)
                </div>

                <div class="field">

                    <label>
                        @Html.CheckBoxFor(m => m.IsAvailable)
                        Đang bán
                    </label>

                    <label>
                        @Html.CheckBoxFor(m => m.IsHot)
                        Sản phẩm Hot
                    </label>

                    <label>
                        @Html.CheckBoxFor(m => m.IsBestSeller)
                        Bán chạy
                    </label>

                    <label>
                        @Html.CheckBoxFor(m => m.IsLock)
                        Khóa sản phẩm
                    </label>

                </div>

                <div class="actions">
                    <button type="submit" class="btn btn-primary">
                        💾 Lưu sản phẩm
                    </button>

                    @Html.ActionLink(
                        "Hủy",
                        "Index",
                        "ManageProduct",
                        null,
                        new { @class = "btn btn-secondary" })
                </div>
            }
        </div>
    </div>

</body>
</html>